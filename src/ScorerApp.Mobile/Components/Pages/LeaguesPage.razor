@page "/leagues"
@using Microsoft.EntityFrameworkCore
@using ScorerApp.Data
@using ScorerApp.Domain.Models
@inject IDbContextFactory<AppDbContext> DbFactory

<PageTitle>Ligy — ScorerApp</PageTitle>

<div class="d-flex align-items-center gap-2 mb-3">
    <i class="bi bi-trophy-fill text-success fs-5"></i>
    <h5 class="mb-0 fw-bold">Ligy</h5>
</div>

@if (_loading)
{
    <div class="text-center py-4">
        <div class="spinner-border spinner-border-sm text-success" role="status"></div>
        <span class="ms-2 small text-muted">Načítání...</span>
    </div>
}
else if (_leagues.Count == 0)
{
    <div class="ui-panel p-4 text-center text-muted">
        <i class="bi bi-inbox fs-3 d-block mb-2"></i>
        Žádné ligy nebyly nalezeny.
    </div>
}
else
{
    <div class="ui-panel p-0">
        @foreach (var league in _leagues)
        {
            <div class="d-flex align-items-center gap-3 px-3 py-2 border-bottom">
                <i class="bi bi-trophy text-success"></i>
                <div class="flex-grow-1">
                    <div class="fw-semibold small">@league.Name</div>
                    <div class="text-muted" style="font-size:.75rem">
                        @league.Sport.Name
                        &bull;
                        @league.Seasons.Count sezón
                    </div>
                </div>
            </div>
        }
    </div>
}

@code {
    private bool _loading = true;
    private List<League> _leagues = new();

    protected override async Task OnInitializedAsync()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        _leagues = await db.Leagues
            .Include(l => l.Sport)
            .Include(l => l.Seasons)
            .OrderBy(l => l.Name)
            .ToListAsync();
        _loading = false;
    }
}
