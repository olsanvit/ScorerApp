@page "/players/{Id:guid}"
@rendermode InteractiveServer
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@inject IDbContextFactory<AppDbContext> DbFactory

<PageTitle>@(_player?.Name ?? "Hráč") — ScorerApp</PageTitle>

@if (_loading)
{
    <div class="ui-anim-fade-up d-flex align-items-center gap-2 mt-4">
        <div class="spinner-border spinner-border-sm text-primary" role="status"></div>
        <span class="text-muted">Načítám…</span>
    </div>
}
else if (_player is null)
{
    <div class="alert alert-warning mt-4">Hráč nebyl nalezen.</div>
}
else
{
    <div class="ui-page-header ui-anim-fade-up">
        <div class="d-flex align-items-center gap-3">
            <a href="/players" class="btn btn-outline-secondary btn-sm"><i class="bi bi-arrow-left"></i></a>
            <h3 class="m-0"><i class="bi bi-person-circle me-2"></i>@_player.Name</h3>
            @if (!string.IsNullOrEmpty(_player.Nickname))
            {
                <span class="badge bg-secondary">@_player.Nickname</span>
            }
        </div>
    </div>

    <div class="row g-4">
        <!-- Info -->
        <div class="col-md-4">
            <div class="ui-panel ui-anim-fade-up">
                <div class="ui-panel-header">
                    <span class="ui-panel-title"><i class="bi bi-person text-accent"></i> Informace</span>
                </div>
                <div class="p-3">
                    <dl class="row mb-0">
                        <dt class="col-5 text-muted">Jméno</dt>
                        <dd class="col-7">@_player.Name</dd>
                        <dt class="col-5 text-muted">Přezdívka</dt>
                        <dd class="col-7">@(_player.Nickname ?? "—")</dd>
                        <dt class="col-5 text-muted">Datum nar.</dt>
                        <dd class="col-7">@(_player.DateOfBirth?.ToString("dd.MM.yyyy") ?? "—")</dd>
                    </dl>
                </div>
            </div>

            <!-- Teams -->
            @if (_player.TeamPlayers.Any())
            {
                <div class="ui-panel ui-anim-fade-up mt-3">
                    <div class="ui-panel-header">
                        <span class="ui-panel-title"><i class="bi bi-shield text-accent"></i> Týmy</span>
                    </div>
                    <div class="p-3">
                        @foreach (var tp in _player.TeamPlayers)
                        {
                            <div class="d-flex align-items-center gap-2 mb-2">
                                <a href="/teams/@tp.Team.Guid" class="text-decoration-none fw-semibold">@tp.Team.Name</a>
                                @if (!string.IsNullOrEmpty(tp.Position))
                                {
                                    <span class="badge bg-secondary small">@tp.Position</span>
                                }
                            </div>
                        }
                    </div>
                </div>
            }
        </div>

        <!-- Season history -->
        <div class="col-md-8">
            <div class="ui-panel ui-anim-fade-up">
                <div class="ui-panel-header">
                    <span class="ui-panel-title"><i class="bi bi-bar-chart text-accent"></i> Historie sezón</span>
                </div>
                @if (!_seasonParticipations.Any())
                {
                    <div class="p-4 text-muted text-center">Hráč zatím nehrál žádnou sezónu.</div>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-hover mb-0">
                            <thead>
                                <tr><th>Sezóna</th><th>Liga</th><th>Sport</th><th class="text-center">ELO</th></tr>
                            </thead>
                            <tbody>
                                @foreach (var sp in _seasonParticipations)
                                {
                                    <tr>
                                        <td class="fw-semibold">
                                            <a href="/seasons/@sp.Season.Guid" class="text-decoration-none">@sp.Season.Name</a>
                                        </td>
                                        <td class="text-muted small">@sp.Season.League.Name</td>
                                        <td class="text-muted small">@sp.Season.League.Sport.Name</td>
                                        <td class="text-center text-muted small">@sp.EloRating.ToString("F0")</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public Guid Id { get; set; }
    private bool _loading = true;
    private Player? _player;
    private List<SeasonParticipant> _seasonParticipations = new();

    protected override async Task OnInitializedAsync()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        _player = await db.Players
            .Include(p => p.TeamPlayers).ThenInclude(tp => tp.Team)
            .FirstOrDefaultAsync(p => p.Guid == Id);

        if (_player is not null)
        {
            _seasonParticipations = await db.SeasonParticipants
                .Where(sp => sp.PlayerId == Id)
                .Include(sp => sp.Season).ThenInclude(s => s.League).ThenInclude(l => l.Sport)
                .OrderByDescending(sp => sp.Season.Year)
                .ToListAsync();
        }
        _loading = false;
    }
}
