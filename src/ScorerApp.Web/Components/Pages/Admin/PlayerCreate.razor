@page "/admin/players/create"
@rendermode InteractiveServer
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Roles = "Admin")]
@inject IDbContextFactory<AppDbContext> DbFactory
@inject SharedServices.ToastService Toast
@inject NavigationManager Nav

<PageTitle>Nový hráč — ScorerApp</PageTitle>

<div class="ui-page-header ui-anim-fade-up">
    <div class="d-flex align-items-center gap-3">
        <a href="/players" class="btn btn-outline-secondary btn-sm"><i class="bi bi-arrow-left"></i></a>
        <h3 class="m-0"><i class="bi bi-person-plus me-2"></i>Nový hráč</h3>
    </div>
</div>

<div class="row justify-content-center">
    <div class="col-md-5">
        <div class="ui-panel ui-anim-fade-up p-4">
            @if (!string.IsNullOrEmpty(_error))
            {
                <div class="alert alert-danger py-2 small mb-3">@_error</div>
            }
            <div class="mb-3">
                <label class="form-label small text-muted">Jméno *</label>
                <input class="form-control" @bind="_name" placeholder="Celé jméno hráče" />
            </div>
            <div class="mb-3">
                <label class="form-label small text-muted">Přezdívka</label>
                <input class="form-control" @bind="_nickname" placeholder="Volitelná přezdívka" />
            </div>
            <div class="mb-4">
                <label class="form-label small text-muted">Datum narození</label>
                <input type="date" class="form-control" @bind="_dob" />
            </div>
            <div class="d-flex gap-2">
                <button class="btn btn-primary" @onclick="SaveAsync" disabled="@_saving">
                    @if (_saving) { <span class="spinner-border spinner-border-sm me-1"></span> }
                    Vytvořit hráče
                </button>
                <a href="/players" class="btn btn-outline-secondary">Zrušit</a>
            </div>
        </div>
    </div>
</div>

@code {
    private string _name = "", _nickname = "", _error = "";
    private DateOnly? _dob;
    private bool _saving;

    private async Task SaveAsync()
    {
        _error = "";
        if (string.IsNullOrWhiteSpace(_name)) { _error = "Zadej jméno hráče."; return; }
        _saving = true;
        await using var db = await DbFactory.CreateDbContextAsync();
        var player = new Player
        {
            Name        = _name.Trim(),
            Nickname    = string.IsNullOrWhiteSpace(_nickname) ? null : _nickname.Trim(),
            DateOfBirth = _dob
        };
        db.Players.Add(player);
        await db.SaveChangesAsync();
        _saving = false;
        Toast.ShowSuccess("Hotovo", $"Hráč \"{_name}\" byl vytvořen.");
        Nav.NavigateTo($"/players/{player.Guid}");
    }
}
