@page "/admin/leagues/create"
@rendermode InteractiveServer
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Roles = "Admin")]
@inject IDbContextFactory<AppDbContext> DbFactory
@inject SharedServices.ToastService Toast
@inject NavigationManager Nav

<PageTitle>Nová liga — ScorerApp</PageTitle>

<div class="ui-page-header ui-anim-fade-up">
    <div class="d-flex align-items-center gap-3">
        <a href="/admin" class="btn btn-outline-secondary btn-sm"><i class="bi bi-arrow-left"></i></a>
        <h3 class="m-0"><i class="bi bi-trophy me-2"></i>Nová liga</h3>
    </div>
</div>

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="ui-panel ui-anim-fade-up p-4">
            @if (!string.IsNullOrEmpty(_error))
            {
                <div class="alert alert-danger py-2 small mb-3">@_error</div>
            }
            <div class="mb-3">
                <label class="form-label small text-muted">Název ligy *</label>
                <input class="form-control" @bind="_name" placeholder="Např. Šipkařská liga Praha" />
            </div>
            <div class="mb-3">
                <label class="form-label small text-muted">Sport *</label>
                <select class="form-select" @bind="_sportId">
                    <option value="">— vyber sport —</option>
                    @foreach (var s in _sports)
                    {
                        <option value="@s.Guid"><i class="bi @s.Icon"></i> @s.Name</option>
                    }
                </select>
            </div>
            <div class="mb-3">
                <label class="form-label small text-muted">Popis</label>
                <textarea class="form-control" rows="3" @bind="_description"
                          placeholder="Volitelný popis ligy…"></textarea>
            </div>
            <div class="mb-4">
                <label class="form-label small text-muted">Vlastní bodovací schéma (JSON, volitelné)</label>
                <textarea class="form-control font-monospace" rows="2" @bind="_scoringOverride"
                          placeholder='{"win":3,"draw":1,"loss":0,"hasDraw":true}'></textarea>
                <div class="form-text">Prázdné = použije se výchozí schéma sportu.</div>
            </div>
            <div class="d-flex gap-2">
                <button class="btn btn-primary" @onclick="SaveAsync" disabled="@_saving">
                    @if (_saving) { <span class="spinner-border spinner-border-sm me-1"></span> }
                    Vytvořit ligu
                </button>
                <a href="/admin" class="btn btn-outline-secondary">Zrušit</a>
            </div>
        </div>
    </div>
</div>

@code {
    private string _name = "", _description = "", _scoringOverride = "";
    private Guid? _sportId;
    private bool _saving;
    private string _error = "";
    private List<Sport> _sports = new();

    protected override async Task OnInitializedAsync()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        _sports = await db.Sports.OrderBy(s => s.Name).ToListAsync();
    }

    private async Task SaveAsync()
    {
        _error = "";
        if (string.IsNullOrWhiteSpace(_name)) { _error = "Zadej název ligy."; return; }
        if (_sportId is null) { _error = "Vyber sport."; return; }

        _saving = true;
        await using var db = await DbFactory.CreateDbContextAsync();
        db.Leagues.Add(new League
        {
            Name = _name.Trim(),
            Description = string.IsNullOrWhiteSpace(_description) ? null : _description.Trim(),
            SportId = _sportId.Value,
            ScoringRulesOverrideJson = string.IsNullOrWhiteSpace(_scoringOverride) ? null : _scoringOverride.Trim()
        });
        await db.SaveChangesAsync();
        _saving = false;
        Toast.ShowSuccess("Hotovo", $"Liga \"{_name}\" byla vytvořena.");
        Nav.NavigateTo("/leagues");
    }
}
