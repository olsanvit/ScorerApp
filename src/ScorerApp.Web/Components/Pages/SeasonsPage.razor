@page "/seasons"
@rendermode InteractiveServer
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@inject IDbContextFactory<AppDbContext> DbFactory

<PageTitle>Sezóny — ScorerApp</PageTitle>

<div class="ui-page-header ui-anim-fade-up">
    <h3><i class="bi bi-calendar3"></i> Sezóny</h3>
    <a href="/admin/seasons/create" class="btn btn-primary btn-sm">
        <i class="bi bi-plus me-1"></i>Nová sezóna
    </a>
</div>

<UiSearchBar @bind-Value="_search"
             Placeholder="Hledat sezónu nebo ligu…"
             Count="@_filtered.Count"
             CountLabel="sezón"
             OnSearch="() => StateHasChanged()" />

@if (_loading)
{
    <div class="ui-anim-fade-up d-flex align-items-center gap-2 mt-3">
        <div class="spinner-border spinner-border-sm text-primary" role="status"></div>
        <span class="text-muted">Načítám…</span>
    </div>
}
else
{
    <!-- Status filter -->
    <div class="d-flex gap-2 mb-3 flex-wrap ui-anim-fade-up">
        @foreach (var (label, filter) in _statusFilters)
        {
            <button class="btn btn-sm @(_statusFilter == filter ? "btn-primary" : "btn-outline-secondary")"
                    @onclick="() => { _statusFilter = filter; StateHasChanged(); }">@label</button>
        }
    </div>

    <div class="ui-panel ui-anim-fade-up">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead>
                    <tr>
                        <th>Sezóna</th>
                        <th>Liga</th>
                        <th>Sport</th>
                        <th>Stav</th>
                        <th>Formát</th>
                        <th class="text-center">Účastníci</th>
                        <th class="text-center">Zápasy</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @if (!_filtered.Any())
                    {
                        <tr><td colspan="8" class="text-muted text-center py-4">Žádné sezóny.</td></tr>
                    }
                    @foreach (var s in _filtered)
                    {
                        <tr>
                            <td class="fw-semibold">
                                <a href="/seasons/@s.Guid" class="text-decoration-none">@s.Name</a>
                            </td>
                            <td class="text-muted small">
                                <a href="/leagues/@s.League.Guid" class="text-decoration-none text-muted">@s.League.Name</a>
                            </td>
                            <td class="text-muted small">
                                <i class="bi @s.League.Sport.Icon me-1"></i>@s.League.Sport.Name
                            </td>
                            <td>
                                <span class="badge @StatusBadge(s.Status)">@StatusLabel(s.Status)</span>
                            </td>
                            <td class="text-muted small">@s.Format</td>
                            <td class="text-center text-muted small">@s.Participants.Count</td>
                            <td class="text-center text-muted small">
                                @s.Matches.Count(m => m.Status == MatchStatus.Played) / @s.Matches.Count
                            </td>
                            <td>
                                <a href="/seasons/@s.Guid" class="btn btn-outline-secondary btn-sm">Detail</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}

@code {
    private bool _loading = true;
    private string _search = "";
    private SeasonStatus? _statusFilter;
    private List<Season> _seasons = new();

    private static readonly (string, SeasonStatus?)[] _statusFilters =
    [
        ("Vše", null),
        ("Aktivní", SeasonStatus.Active),
        ("Plánování", SeasonStatus.Planning),
        ("Dokončené", SeasonStatus.Finished)
    ];

    private List<Season> _filtered => _seasons
        .Where(s => (_statusFilter is null || s.Status == _statusFilter)
                 && (string.IsNullOrWhiteSpace(_search)
                     || s.Name.Contains(_search, StringComparison.OrdinalIgnoreCase)
                     || s.League.Name.Contains(_search, StringComparison.OrdinalIgnoreCase)))
        .ToList();

    protected override async Task OnInitializedAsync()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        _seasons = await db.Seasons
            .Include(s => s.League).ThenInclude(l => l.Sport)
            .Include(s => s.Participants)
            .Include(s => s.Matches)
            .OrderByDescending(s => s.Year).ThenBy(s => s.Name)
            .ToListAsync();
        _loading = false;
    }

    private static string StatusBadge(SeasonStatus s) => s switch
    {
        SeasonStatus.Active   => "bg-success",
        SeasonStatus.Finished => "bg-secondary",
        _                     => "bg-warning text-dark"
    };
    private static string StatusLabel(SeasonStatus s) => s switch
    {
        SeasonStatus.Active   => "Aktivní",
        SeasonStatus.Finished => "Dokončena",
        _                     => "Plánování"
    };
}
