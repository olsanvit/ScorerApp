@using Microsoft.AspNetCore.Components.Authorization
@inject AuthenticationStateProvider AuthStateProvider

<div class="top-row ps-3 navbar navbar-dark">
    <div class="container-fluid">
        <a class="navbar-brand fw-bold" href="">
            <i class="bi bi-trophy-fill me-2 text-accent"></i>ScorerApp
        </a>
    </div>
</div>

<input type="checkbox" title="Navigation menu" class="navbar-toggler" />

<div class="nav-scrollable" onclick="document.querySelector('.navbar-toggler').click()">
    <nav class="nav flex-column">
        <AuthorizeView>
            <Authorized>
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="" Match="NavLinkMatch.All">
                        <i class="bi bi-house-door me-2"></i> Dashboard
                    </NavLink>
                </div>
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="/leagues">
                        <i class="bi bi-trophy me-2"></i> Ligy
                    </NavLink>
                </div>
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="/seasons">
                        <i class="bi bi-calendar3 me-2"></i> Sezóny
                    </NavLink>
                </div>
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="/matches">
                        <i class="bi bi-controller me-2"></i> Zápasy
                    </NavLink>
                </div>
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="/players">
                        <i class="bi bi-people me-2"></i> Hráči
                    </NavLink>
                </div>
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="/teams">
                        <i class="bi bi-shield me-2"></i> Týmy
                    </NavLink>
                </div>

                <AuthorizeView Roles="Admin" Context="adminCtx">
                    <Authorized>
                        <hr class="nav-divider" />
                        <div class="nav-item px-3">
                            <NavLink class="nav-link" href="/admin">
                                <i class="bi bi-shield-lock me-2"></i> Admin
                            </NavLink>
                        </div>
                    </Authorized>
                </AuthorizeView>

                <hr class="nav-divider" />
                <div class="nav-item px-3">
                    <span class="nav-link text-muted small">
                        <i class="bi bi-person-circle me-1"></i>@context.User.Identity?.Name
                    </span>
                </div>
                <div class="nav-item px-3">
                    <a class="nav-link" href="/logout">
                        <i class="bi bi-box-arrow-right me-2"></i> Odhlásit
                    </a>
                </div>
                <ThemePicker />
            </Authorized>
            <NotAuthorized>
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="/login">
                        <i class="bi bi-box-arrow-in-right me-2"></i> Přihlásit
                    </NavLink>
                </div>
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="/register">
                        <i class="bi bi-person-plus me-2"></i> Registrace
                    </NavLink>
                </div>
            </NotAuthorized>
        </AuthorizeView>
    </nav>
</div>

<style>
    .nav-divider { border-color: rgba(255,255,255,.15); margin: .5rem 1rem; }
</style>
