@page "/login"
@rendermode InteractiveServer
@using Microsoft.AspNetCore.Authentication
@inject SignInManager<AppUser> SignInManager
@inject NavigationManager Nav

<PageTitle>Přihlášení — ScorerApp</PageTitle>

<div class="row justify-content-center mt-5">
    <div class="col-md-4">
        <div class="ui-panel ui-anim-fade-up p-4">
            <h4 class="mb-4"><i class="bi bi-trophy-fill text-accent me-2"></i>ScorerApp</h4>
            @if (!string.IsNullOrEmpty(_error))
            {
                <div class="alert alert-danger py-2 small">@_error</div>
            }
            <div class="mb-3">
                <label class="form-label small text-muted">Email</label>
                <input class="form-control" type="email" @bind="_email" @bind:event="oninput" />
            </div>
            <div class="mb-3">
                <label class="form-label small text-muted">Heslo</label>
                <input class="form-control" type="password" @bind="_password" @bind:event="oninput"
                       @onkeydown="OnKeyDown" />
            </div>
            <button class="btn btn-primary w-100" @onclick="LoginAsync" disabled="@_loading">
                @if (_loading) { <span class="spinner-border spinner-border-sm me-1"></span> }
                Přihlásit
            </button>
            <div class="mt-3 text-center small text-muted">
                Nemáš účet? <a href="/register">Registruj se</a>
            </div>
        </div>
    </div>
</div>

@code {
    private string _email = "", _password = "", _error = "";
    private bool _loading;

    private async Task OnKeyDown(KeyboardEventArgs e)
    { if (e.Key == "Enter") await LoginAsync(); }

    private async Task LoginAsync()
    {
        _error = ""; _loading = true;
        var result = await SignInManager.PasswordSignInAsync(_email, _password, isPersistent: true, lockoutOnFailure: false);
        _loading = false;
        if (result.Succeeded) Nav.NavigateTo("/", forceLoad: true);
        else _error = "Neplatné přihlašovací údaje.";
    }
}
